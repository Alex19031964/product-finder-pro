from __future__ import annotations
import pandas as pd


def estimate_marketplace_fees(price: float, marketplace: str) -> float:
    marketplace = str(marketplace).lower()
    if "amazon" in marketplace:
        referral = price * 0.15
        fulfilment = 3.25 if price < 30 else 4.95
        return round(referral + fulfilment, 2)
    if "ebay" in marketplace:
        return round(price * 0.128 + 0.30, 2)
    if "walmart" in marketplace:
        return round(price * 0.15, 2)
    return round(price * 0.12, 2)


def competition_label(score: int) -> str:
    if score <= 1:
        return "Low"
    if score == 2:
        return "Medium"
    return "High"


def opportunity_label(roi: float, monthly_sales: int, competition_score: int) -> str:
    if roi >= 60 and monthly_sales >= 300 and competition_score <= 2:
        return "High"
    if roi >= 30 and monthly_sales >= 120:
        return "Medium"
    return "Low"


def opportunity_score(roi: float, monthly_sales: int, competition_score: int) -> int:
    score = 0
    if roi >= 80:
        score += 40
    elif roi >= 60:
        score += 34
    elif roi >= 40:
        score += 26
    elif roi >= 25:
        score += 15

    if monthly_sales >= 1500:
        score += 40
    elif monthly_sales >= 700:
        score += 32
    elif monthly_sales >= 300:
        score += 24
    elif monthly_sales >= 120:
        score += 12

    if competition_score <= 1:
        score += 20
    elif competition_score == 2:
        score += 10

    return min(score, 100)


def scan_products(supplier_df: pd.DataFrame, marketplace_df: pd.DataFrame, other_expenses: float = 1.50) -> pd.DataFrame:
    required_supplier = {"product_name", "category", "supplier", "cost", "shipping_cost", "moq", "lead_time_days"}
    required_market = {"product_name", "marketplace", "selling_price", "estimated_monthly_sales", "competition_score"}

    missing_supplier = required_supplier - set(supplier_df.columns)
    missing_market = required_market - set(marketplace_df.columns)

    if missing_supplier:
        raise ValueError(f"Supplier data missing columns: {', '.join(sorted(missing_supplier))}")
    if missing_market:
        raise ValueError(f"Marketplace data missing columns: {', '.join(sorted(missing_market))}")

    rows = []
    market_lookup = marketplace_df.set_index("product_name").to_dict("index")

    for _, p in supplier_df.iterrows():
        product = p["product_name"]
        m = market_lookup.get(product)

        if not m:
            m = {
                "marketplace": "Amazon UK",
                "selling_price": float(p["cost"]) * 2.8,
                "estimated_monthly_sales": 100,
                "competition_score": 2,
            }

        price = float(m["selling_price"])
        cost = float(p["cost"])
        shipping = float(p["shipping_cost"])
        sales = int(float(m["estimated_monthly_sales"]))
        comp_score = int(float(m["competition_score"]))
        fees = estimate_marketplace_fees(price, str(m["marketplace"]))
        total_cost = cost + shipping + fees + other_expenses
        profit = price - total_cost
        roi = (profit / total_cost * 100) if total_cost else 0
        monthly_revenue = price * sales
        monthly_profit = profit * sales

        rows.append({
            "Product": product,
            "Category": p["category"],
            "Supplier": p["supplier"],
            "Marketplace": m["marketplace"],
            "Supplier Cost": round(cost, 2),
            "Shipping": round(shipping, 2),
            "MOQ": int(float(p["moq"])),
            "Lead Time Days": int(float(p["lead_time_days"])),
            "Selling Price": round(price, 2),
            "Marketplace Fees": round(fees, 2),
            "Other Expenses": round(other_expenses, 2),
            "Total Cost": round(total_cost, 2),
            "Profit Per Unit": round(profit, 2),
            "ROI %": round(roi, 2),
            "Monthly Sales": sales,
            "Monthly Revenue": round(monthly_revenue, 2),
            "Monthly Profit": round(monthly_profit, 2),
            "Competition": competition_label(comp_score),
            "Competition Score": comp_score,
            "Opportunity": opportunity_label(roi, sales, comp_score),
            "Opportunity Score": opportunity_score(roi, sales, comp_score),
        })

    df = pd.DataFrame(rows)
    return df.sort_values(["Opportunity Score", "Monthly Profit", "ROI %"], ascending=False)


def revenue_projection(monthly_revenue: float, growth_rate: float, months: int = 6) -> pd.DataFrame:
    values = []
    current = monthly_revenue
    for month in range(1, months + 1):
        values.append({"Month": f"Month {month}", "Projected Revenue": round(current, 2)})
        current *= 1 + growth_rate
    return pd.DataFrame(values)
