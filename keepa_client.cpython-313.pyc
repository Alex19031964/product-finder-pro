from pathlib import Path
import sqlite3
import pandas as pd

DB_PATH = Path("product_finder_web.db")


def init_db():
    with sqlite3.connect(DB_PATH) as conn:
        conn.execute("""
            CREATE TABLE IF NOT EXISTS scans (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                created_at TEXT DEFAULT CURRENT_TIMESTAMP,
                product TEXT,
                category TEXT,
                supplier TEXT,
                marketplace TEXT,
                supplier_cost REAL,
                shipping REAL,
                moq INTEGER,
                lead_time_days INTEGER,
                selling_price REAL,
                marketplace_fees REAL,
                other_expenses REAL,
                total_cost REAL,
                profit_per_unit REAL,
                roi_percent REAL,
                monthly_sales INTEGER,
                monthly_revenue REAL,
                monthly_profit REAL,
                competition TEXT,
                competition_score INTEGER,
                opportunity TEXT,
                opportunity_score INTEGER
            )
        """)


def save_scan(df: pd.DataFrame):
    init_db()
    renamed = df.rename(columns={
        "Product": "product",
        "Category": "category",
        "Supplier": "supplier",
        "Marketplace": "marketplace",
        "Supplier Cost": "supplier_cost",
        "Shipping": "shipping",
        "MOQ": "moq",
        "Lead Time Days": "lead_time_days",
        "Selling Price": "selling_price",
        "Marketplace Fees": "marketplace_fees",
        "Other Expenses": "other_expenses",
        "Total Cost": "total_cost",
        "Profit Per Unit": "profit_per_unit",
        "ROI %": "roi_percent",
        "Monthly Sales": "monthly_sales",
        "Monthly Revenue": "monthly_revenue",
        "Monthly Profit": "monthly_profit",
        "Competition": "competition",
        "Competition Score": "competition_score",
        "Opportunity": "opportunity",
        "Opportunity Score": "opportunity_score",
    })
    cols = [
        "product", "category", "supplier", "marketplace", "supplier_cost", "shipping",
        "moq", "lead_time_days", "selling_price", "marketplace_fees", "other_expenses",
        "total_cost", "profit_per_unit", "roi_percent", "monthly_sales", "monthly_revenue",
        "monthly_profit", "competition", "competition_score", "opportunity", "opportunity_score"
    ]
    with sqlite3.connect(DB_PATH) as conn:
        renamed[cols].to_sql("scans", conn, if_exists="append", index=False)


def load_recent_scans(limit: int = 250) -> pd.DataFrame:
    init_db()
    with sqlite3.connect(DB_PATH) as conn:
        return pd.read_sql_query(
            "SELECT * FROM scans ORDER BY created_at DESC LIMIT ?",
            conn,
            params=(limit,),
        )


def clear_history():
    init_db()
    with sqlite3.connect(DB_PATH) as conn:
        conn.execute("DELETE FROM scans")
